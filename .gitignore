# ==========================================
# Dependencies & Package Managers
# ==========================================
**/node_modules/
**/jspm_packages/
**/web_modules/

# Backend Ecosystems (Python, Ruby, PHP, Java)
**/__pycache__/
**/*.py[cod]
**/venv/
**/.venv/
**/env/
**/.env/
**/vendor/
**/target/

# ==========================================
# Build Outputs & Bundlers
# ==========================================
**/dist/
**/dist-ssr/
**/out/
**/bin/
**/obj/
**/.next/
**/.nuxt/
**/.cache/
**/.turbo/

# ==========================================
# Environment Variables & Secrets
# ==========================================
**/*.local
**/.env
**/.env.*
**/*.pem
**/*.key
**/*.secret

# ==========================================
# Logs and Debugging
# ==========================================
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# ==========================================
# IDE, Editors, and OS Files
# ==========================================
**/.vscode/*
!**/.vscode/extensions.json
**/.idea/
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln
**/*.sw?
**/.DS_Store
**/Thumbs.db
